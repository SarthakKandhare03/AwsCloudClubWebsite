# ============================================================
# AWS Cloud Club NMIET — Environment Variables Template
# Copy this to .env.local and fill in values from AWS Console
# NEVER commit .env.local to git!
# ============================================================

# ── Cognito (Auth) ───────────────────────────────────────────
NEXT_PUBLIC_COGNITO_REGION=ap-south-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# Client secret from your Cognito App Client (server-side only — never expose to browser)
COGNITO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── DynamoDB ─────────────────────────────────────────────────
# Table names (you'll create these via setup script)
DYNAMODB_EVENTS_TABLE=acc-nmiet-events
DYNAMODB_TEAM_TABLE=acc-nmiet-team
DYNAMODB_PROJECTS_TABLE=acc-nmiet-projects
DYNAMODB_ACHIEVEMENTS_TABLE=acc-nmiet-achievements
DYNAMODB_RESOURCES_TABLE=acc-nmiet-resources
DYNAMODB_SOCIAL_TABLE=acc-nmiet-social-links
DYNAMODB_CONFIG_TABLE=acc-nmiet-site-config
DYNAMODB_CONTACTS_TABLE=acc-nmiet-contact-submissions
DYNAMODB_PROFILES_TABLE=acc-nmiet-user-profiles

# ── S3 + CloudFront (Media Storage) ──────────────────────────
NEXT_PUBLIC_S3_BUCKET=acc-nmiet-media
NEXT_PUBLIC_S3_REGION=ap-south-1
NEXT_PUBLIC_CLOUDFRONT_URL=https://XXXXXXXXXXXX.cloudfront.net

# ── SES (Email — Contact Form) ───────────────────────────────
SES_REGION=ap-south-1
SES_FROM_EMAIL=awscloudclub.nmiet@gmail.com
SES_TO_EMAIL=awscloudclub.nmiet@gmail.com

# ── AWS Server-Side Credentials ──────────────────────────────
# These are ONLY used server-side in API routes (never exposed to browser)
AWS_ACCESS_KEY_ID=XXXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=ap-south-1

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-amplify-domain.amplifyapp.com

# ── Meetup Overrides ─────────────────────────────────────────
# If the Meetup API returns wrong member count, set this manually (check meetup.com page)
MEETUP_MEMBER_COUNT=299
